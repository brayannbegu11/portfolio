---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { featuredProjects, moreProjects } from '../data/projects';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<article class="portfolio" data-page="portfolio">
  <header>
    <h2 class="h2 article-title">Portfolio</h2>
  </header>

  <section class="projects">
    <p class="section-label">Featured case studies</p>

    <ul class="project-list">
      {
        featuredProjects.map((project) => (
          <li class="project-item active">
            <a href={`${base}/projects/${project.slug}`}>
              <figure class="project-img">
                <div class="project-item-icon-box">
                  <Icon name="ion:arrow-forward-outline" />
                </div>
                <Image
                  src={project.image}
                  alt={project.title}
                  loading="lazy"
                  widths={[300, 600]}
                  sizes="(min-width: 1024px) 300px, (min-width: 768px) 50vw, 100vw"
                />
              </figure>
              <h3 class="project-title">{project.title}</h3>
              <p class="project-tagline">{project.tagline}</p>
              <ul class="card-tech">
                {project.tech.slice(0, 4).map((t) => <li>{t}</li>)}
              </ul>
              <span class="project-cta">
                Read case study <Icon name="ion:arrow-forward-outline" />
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <div class="more-projects">
      <p class="section-label">More projects</p>

      <ul class="more-grid">
        {
          moreProjects.map((project) => (
            <li class="more-item">
              <div class="more-info">
                <h4>{project.title}</h4>
                <p>{project.tagline}</p>
              </div>
              <div class="more-links">
                {project.liveUrl && (
                  <a
                    href={project.liveUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${project.title} live demo`}
                  >
                    <Icon name="ion:open-outline" />
                  </a>
                )}
                {project.repoUrl && (
                  <a
                    href={project.repoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${project.title} source code`}
                  >
                    <Icon name="ion:logo-github" />
                  </a>
                )}
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</article>
