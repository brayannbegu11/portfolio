---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { profile } from '../data/profile';
import avatar from '../assets/profile.jpeg';
---

<aside class="sidebar" data-sidebar>
  <div class="sidebar-info">
    <figure class="avatar-box">
      <Image src={avatar} alt={profile.name} width={150} height={150} />
    </figure>

    <div class="info-content">
      <h1 class="name" title={profile.name}>{profile.name}</h1>
      <p class="title">{profile.title}</p>
    </div>

    <button class="info_more-btn" data-sidebar-btn aria-label="Show contacts">
      <span>Show Contacts</span>
      <Icon name="ion:chevron-down" />
    </button>
  </div>

  <div class="sidebar-info_more">
    <div class="separator"></div>

    <ul class="contacts-list">
      <li class="contact-item">
        <div class="icon-box"><Icon name="ion:mail-outline" /></div>
        <div class="contact-info">
          <p class="contact-title">Email</p>
          <a href={`mailto:${profile.email}`} class="contact-link">{profile.email}</a>
        </div>
      </li>

      <li class="contact-item">
        <div class="icon-box"><Icon name="ion:location-outline" /></div>
        <div class="contact-info">
          <p class="contact-title">Location</p>
          <address>{profile.location}</address>
        </div>
      </li>
    </ul>

    <div class="separator"></div>

    <ul class="social-list">
      {
        profile.socials.map((social) => (
          <li class="social-item">
            <a
              href={social.url}
              class="social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.name}
            >
              <Icon name={social.icon} />
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</aside>
