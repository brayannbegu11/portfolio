---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import { featuredProjects } from '../../data/projects';
import { profile } from '../../data/profile';

export function getStaticPaths() {
  return featuredProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const cs = project.caseStudy!;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: project.title,
  applicationCategory:
    project.category === 'mobile development' ? 'MobileApplication' : 'WebApplication',
  operatingSystem: project.category === 'mobile development' ? 'iOS, Android' : 'Web',
  description: project.tagline,
  author: {
    '@type': 'Person',
    name: profile.name,
    url: new URL(`${base}/`, Astro.site).href,
  },
  ...(project.liveUrl ? { url: project.liveUrl } : {}),
  ...(project.repoUrl ? { codeRepository: project.repoUrl } : {}),
};
---

<Layout title={`${project.title} — ${profile.name}`} description={project.tagline}>
  <main class="cs-main">
    <div class="cs-card">
      <a class="cs-back" href={`${homeHref}#portfolio`}>
        <Icon name="ion:arrow-back-outline" /> Back to portfolio
      </a>

      <header>
        <p class="cs-category">{project.category}</p>
        <h1 class="h2 article-title">{project.title}</h1>
        <p class="cs-tagline">{project.tagline}</p>

        <ul class="tech-chips">
          {project.tech.map((t) => <li>{t}</li>)}
        </ul>

        <div class="cs-actions">
          {
            project.liveUrl && (
              <a class="form-btn" href={project.liveUrl} target="_blank" rel="noopener noreferrer">
                <Icon name="ion:open-outline" />
                <span>Live demo</span>
              </a>
            )
          }
          {
            project.repoUrl && (
              <a class="form-btn ghost" href={project.repoUrl} target="_blank" rel="noopener noreferrer">
                <Icon name="ion:logo-github" />
                <span>View code</span>
              </a>
            )
          }
        </div>
      </header>

      <figure class="cs-image">
        <Image
          src={project.image}
          alt={`${project.title} screenshot`}
          widths={[480, 820]}
          sizes="(min-width: 860px) 820px, 100vw"
        />
      </figure>

      <section class="cs-section">
        <h2>The problem</h2>
        <p>{cs.problem}</p>
      </section>

      <section class="cs-section">
        <h2>My role</h2>
        <p>{cs.role}</p>
      </section>

      <section class="cs-section">
        <h2>Key decisions</h2>
        <ul class="bullet-list">
          {cs.decisions.map((d) => <li>{d}</li>)}
        </ul>
      </section>

      <section class="cs-section">
        <h2>Outcome</h2>
        <p>{cs.outcome}</p>
        {
          cs.metrics && (
            <ul class="metrics">
              {cs.metrics.map((m) => (
                <li class="metric">
                  <Icon name="ion:checkmark-circle-outline" />
                  <span>{m}</span>
                </li>
              ))}
            </ul>
          )
        }
      </section>
    </div>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</Layout>
